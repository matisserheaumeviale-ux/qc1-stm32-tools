{
  "name": "QC1-STM32-Tools",
  "displayName": "QC1 STM32F103 Tools",
  "description": "Interface VSCode pour Quick Command STM32",
  "version": "0.0.6",
  "publisher": "Mistral400",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/matisserheaumeviale-ux/qc1-stm32-tools.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "activationEvents": [
    "onView:qc1.panel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qc1",
          "title": "QC1",
          "icon": "media/qc1.svg"
        }
      ]
    },
    "views": {
      "qc1": [
        {
          "id": "qc1.panel",
          "name": "STM32 Control",
          "type": "webview",
          "icon": "media/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "qc1.build",
        "title": "QC1: Build"
      },
      {
        "command": "qc1.tsmake",
        "title": "QC1: Test Build"
      },
      {
        "command": "qc1.flash",
        "title": "QC1: Flash"
      },
      {
        "command": "qc1.health",
        "title": "QC1: Health Check"
      },
      {
        "command": "qc1.status",
        "title": "QC1: Status"
      },
      {
        "command": "qc1.error",
        "title": "QC1: Errors"
      },
      {
        "command": "qc1.dev",
        "title": "QC1: Dev Mode"
      }
    ],
    "configuration": {
      "title": "QC1 STM32 Tools",
      "properties": {
        "qc1.quickCommandPath": {
          "type": "string",
          "default": "./scripts/quick-command",
          "description": "Path to the quick-command script."
        },
        "qc1.autoClearOutput": {
          "type": "boolean",
          "default": false,
          "description": "Automatically clear output before running a command."
        },
        "qc1.autoRefreshStatus": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh QC1 status."
        },
        "qc1.enablePointerVisualizer": {
          "type": "boolean",
          "default": true,
          "description": "Enable the C pointer visualizer."
        },
        "qc1.pointerVisualizerMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum pointer indirection depth to visualize."
        },
        "qc1.visualizerTheme": {
          "type": "string",
          "enum": ["auto", "dark", "light"],
          "default": "auto",
          "description": "Theme for the pointer visualizer."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.0.0"
  }
}
