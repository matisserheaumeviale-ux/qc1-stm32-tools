{
  "name": "qc1-stm32-tools",
  "displayName": "QC1 STM32F103 Tools",
  "description": "Interface VSCode pour Quick Command STM32",
  "version": "0.0.10",
  "publisher": "Mistral400",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/matisserheaumeviale-ux/qc1-stm32-tools.git"
  },
  "files": [
    "out/**",
    "media/**",
    "resources/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.118.0"
  },
  "activationEvents": [
    "onView:qc1.panel",
    "workspaceContains:Makefile",
    "workspaceContains:**/*.ioc",
    "workspaceContains:**/*.eww",
    "workspaceContains:**/*.ewp",
    "onCommand:qc1.build",
    "onCommand:qc1.flash",
    "onCommand:qc1.run",
    "onCommand:qc1.status"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qc1",
          "title": "QC1 STM32",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "qc1": [
        {
          "id": "qc1.panel",
          "name": "STM32 Tools",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "qc1.build",
        "title": "Build Project",
        "category": "QC1 STM32",
        "icon": "$(tools)"
      },
      {
        "command": "qc1.clean",
        "title": "Clean Project",
        "category": "QC1 STM32",
        "icon": "$(trash)"
      },
      {
        "command": "qc1.rebuild",
        "title": "Rebuild Project",
        "category": "QC1 STM32",
        "icon": "$(sync)"
      },
      {
        "command": "qc1.tsmake",
        "title": "QC1: Test Build"
      },
      {
        "command": "qc1.flash",
        "title": "Flash STM32",
        "category": "QC1 STM32",
        "icon": "$(debug-start)"
      },
      {
        "command": "qc1.run",
        "title": "Build + Flash + Status",
        "category": "QC1 STM32",
        "icon": "$(play)"
      },
      {
        "command": "qc1.health",
        "title": "QC1: Health Check"
      },
      {
        "command": "qc1.status",
        "title": "Show STM32 Status",
        "category": "QC1 STM32",
        "icon": "$(pulse)"
      },
      {
        "command": "qc1.error",
        "title": "QC1: Errors"
      },
      {
        "command": "qc1.detectStlink",
        "title": "Detect ST-Link",
        "category": "QC1 STM32",
        "icon": "$(search)"
      },
      {
        "command": "qc1.openSerial",
        "title": "Open Serial Monitor",
        "category": "QC1 STM32",
        "icon": "$(plug)"
      },
      {
        "command": "qc1.startOpenOcd",
        "title": "Start OpenOCD",
        "category": "QC1 STM32",
        "icon": "$(radio-tower)"
      },
      {
        "command": "qc1.configure",
        "title": "Configure QC1 STM32 Tools",
        "category": "QC1 STM32",
        "icon": "$(settings-gear)"
      },
      {
        "command": "qc1.refresh",
        "title": "Refresh QC1 Panel",
        "category": "QC1 STM32",
        "icon": "$(refresh)"
      },
      {
        "command": "qc1.dev",
        "title": "QC1: Dev Mode"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "qc1.build"
        },
        {
          "command": "qc1.clean"
        },
        {
          "command": "qc1.rebuild"
        },
        {
          "command": "qc1.flash"
        },
        {
          "command": "qc1.run"
        },
        {
          "command": "qc1.status"
        },
        {
          "command": "qc1.detectStlink"
        },
        {
          "command": "qc1.openSerial"
        },
        {
          "command": "qc1.startOpenOcd"
        },
        {
          "command": "qc1.configure"
        }
      ],
      "view/title": [
        {
          "command": "qc1.refresh",
          "when": "view == qc1.panel",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "qc1.build",
          "when": "view == qc1.panel",
          "group": "inline"
        },
        {
          "command": "qc1.flash",
          "when": "view == qc1.panel",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "QC1 STM32 Tools",
      "properties": {
        "qc1.quickCommandPath": {
          "type": "string",
          "default": "",
          "description": "Optional custom path to quick-command. If empty, QC1 uses its built-in portable script."
        },
        "qc1.serialPort": {
          "type": "string",
          "default": "",
          "description": "Serial port used for STM32 UART"
        },
        "qc1.baudRate": {
          "type": "number",
          "default": 19200,
          "description": "UART baud rate"
        },
        "qc1.openocdPath": {
          "type": "string",
          "default": "openocd",
          "description": "Path to OpenOCD executable"
        },
        "qc1.stlinkPath": {
          "type": "string",
          "default": "st-info",
          "description": "Path to ST-Link command line tool"
        },
        "qc1.autoDetectProject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect STM32 project files"
        },
        "qc1.autoClearOutput": {
          "type": "boolean",
          "default": false,
          "description": "Clear output before running"
        },
        "qc1.showTimestamps": {
          "type": "boolean",
          "default": true,
          "description": "Show timestamps in output"
        },
        "qc1.outputMaxLines": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 5000,
          "description": "Max output lines"
        },
        "qc1.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "Compact UI mode"
        },
        "qc1.autoRefreshStatus": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh status"
        },
        "qc1.enablePointerVisualizer": {
          "type": "boolean",
          "default": true,
          "description": "Enable pointer visualizer"
        },
        "qc1.pointerVisualizerMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Pointer depth"
        },
        "qc1.visualizerTheme": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "default": "auto",
          "description": "Visualizer theme"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.0.0"
  }
}
