{
  "name": "qc1-stm32-tools",
  "displayName": "QC1 STM32F103 Tools",
  "description": "Interface VSCode pour Quick Command STM32",
  "version": "0.0.7",
  "publisher": "Mistral400",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/matisserheaumeviale-ux/qc1-stm32-tools.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "activationEvents": [
    "onView:qc1.panel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qc1",
          "title": "QC1",
          "icon": "media/qc1.svg"
        }
      ]
    },
    "views": {
      "qc1": [
        {
          "id": "qc1.panel",
          "name": "STM32 Control",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "qc1.build",
        "title": "QC1: Build"
      },
      {
        "command": "qc1.tsmake",
        "title": "QC1: Test Build"
      },
      {
        "command": "qc1.flash",
        "title": "QC1: Flash"
      },
      {
        "command": "qc1.health",
        "title": "QC1: Health Check"
      },
      {
        "command": "qc1.status",
        "title": "QC1: Status"
      },
      {
        "command": "qc1.error",
        "title": "QC1: Errors"
      },
      {
        "command": "qc1.dev",
        "title": "QC1: Dev Mode"
      }
    ],
    "configuration": {
      "title": "QC1 STM32 Tools",
      "properties": {
        "qc1.quickCommandPath": {
          "type": "string",
          "default": "./scripts/quick-command",
          "description": "Path to quick-command script"
        },
        "qc1.autoClearOutput": {
          "type": "boolean",
          "default": false,
          "description": "Clear output before running"
        },
        "qc1.showTimestamps": {
          "type": "boolean",
          "default": true,
          "description": "Show timestamps in output"
        },
        "qc1.outputMaxLines": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 5000,
          "description": "Max output lines"
        },
        "qc1.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "Compact UI mode"
        },
        "qc1.autoRefreshStatus": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh status"
        },
        "qc1.enablePointerVisualizer": {
          "type": "boolean",
          "default": true,
          "description": "Enable pointer visualizer"
        },
        "qc1.pointerVisualizerMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Pointer depth"
        },
        "qc1.visualizerTheme": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "default": "auto",
          "description": "Visualizer theme"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.0.0"
  }
}
